<resources>
    <!-- Top app bar / actions -->
    <string name="movies_listing_title">Trending this week</string>
    <string name="movies_listing_sort_action">Sort</string>
    <string name="movies_listing_refresh_action">Refresh</string>

    <!--
      DomainError → user-facing copy. Owned by the screen (not the VM) so each error variant
      maps to a localisable string resource and translators can adjust per-screen wording.
    -->
    <string name="movies_listing_error_title">Couldn\'t load movies</string>
    <string name="movies_listing_error_network">No internet connection. Check your network and try again.</string>
    <string name="movies_listing_error_server">Something went wrong on our side (code %1$d). Please try again.</string>
    <!--
      Distinct from the generic server / unknown copy: a parsing failure means the response
      shape is incompatible, so retrying won't help and we tell the user that explicitly.
    -->
    <string name="movies_listing_error_parsing">We received an unexpected response from the server. The app may need to be updated.</string>
    <string name="movies_listing_error_cancelled">Request cancelled.</string>
    <string name="movies_listing_error_unknown">Unexpected error. Please try again.</string>

    <!-- Empty filter result -->
    <string name="movies_listing_empty_filter_title">No movies match the selected genres.</string>
    <string name="movies_listing_empty_filter_message">Try removing a genre to see more results.</string>

